{
  "name": "pixel-pay",
  "private": true,
  "workspaces": [
    "database",
    "apps/admin",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "cd apps/api && cargo watch -x run",
    "dev:admin": "npm run dev -w apps/admin",
    "dev:web": "npm run dev -w apps/web",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:admin\" \"npm run dev:web\"",
    "db:push": "npm run push -w database",
    "db:seed": "npm run seed -w database",
    "db:studio": "npm run studio -w database",
    "build:admin": "npm run build -w apps/admin",
    "build:web": "npm run build -w apps/web",
    "build": "npm run build:admin && npm run build:web && cd apps/api && cargo build --release"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "allowScripts": {
    "es5-ext@0.10.64": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.0": true
  }
}
